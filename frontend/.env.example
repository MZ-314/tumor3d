# Point chat UI at RunPod API (no trailing slash).
# Find URL under RunPod → Connect → HTTP services → Port 8000
# VITE_API_BASE=https://occupational_olive_wasp-8000.proxy.runpod.net

# Optional: proxy local dev to RunPod instead of localhost (if VITE_API_BASE is unset)
# VITE_API_PROXY_TARGET=https://occupational_olive_wasp-8000.proxy.runpod.net
