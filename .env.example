# Medical chat API — copy to .env and adjust

# CPU demo (laptop / Mac M1) — NOT SUPPORTED for clinical path; use RunPod GPU
SEGMENTATION_BACKEND=monai

# Data and chat history
DATA_DIR=./data
CHAT_DB_PATH=./data/chat.db

# Optional Groq narration (NEVER commit real keys — set on RunPod or in local .env only)
# GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# Multi-stage reconstruction pipeline (Phases 0–10) — GPU required for brain MRI
RECONSTRUCT_PIPELINE_VERSION=0.1.0
PARTIAL_VOLUME_MIN_SLICES=6
MULTI_SLICE_MIN_SLICES=10
# ATLAS_BRAIN_DIR=./data/atlases/brain
# ATLAS_KNEE_DIR=./data/atlases/knee
# VALIDATION_DICE_MIN=0.5

# Voxel spacing when DICOM metadata missing (mm)
DEFAULT_PIXEL_SPACING_MM=1.0
DEFAULT_SLICE_THICKNESS_MM=5.0

# GPU / RunPod (MONAI)
# SEGMENTATION_BACKEND=monai
# MONAI_BUNDLE_DIR=/workspace/monai_bundle
